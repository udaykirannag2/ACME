# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Note: .terraform.lock.hcl IS committed to pin provider versions.
# tfvars often contain account-specific values; commit only the .example.
terraform.tfvars
*.auto.tfvars
# Terraform archive_file build artifacts (Lambda zips)
.build/

# AWS / secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials
config

# dbt
target/
dbt_packages/
logs/
.user.yml

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — never commit synthetic dumps to git
generators/_out/
*.parquet
*.csv
!docs/reference/*.csv

# Node
node_modules/

# Course build artifacts (QA screenshots, intermediates)
docs/course/*.jpg
docs/course/*.pdf
docs/course/qa_slides/
docs/course/qa_thumbs/
docs/course/s*-qa/
docs/course/slides/
~$*.pptx

