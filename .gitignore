# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Note: .terraform.lock.hcl IS committed to pin provider versions.
# tfvars often contain account-specific values; commit only the .example.
terraform.tfvars
*.auto.tfvars

# AWS / secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials
config

# dbt
target/
dbt_packages/
logs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — never commit synthetic dumps to git
generators/_out/
*.parquet
*.csv
!docs/reference/*.csv

# OS
.DS_Store
Thumbs.db

