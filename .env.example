# Copy to .env and fill in. .env is gitignored.

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=acme-finance

# Project tags (applied by Terraform)
PROJECT_TAG=acme-finance
ENV_TAG=dev
OWNER_TAG=uday

# S3 lake buckets (set after first terraform apply)
S3_LAKE_RAW=
S3_LAKE_CURATED=
S3_LAKE_KB=

# Redshift Serverless (set after first terraform apply)
REDSHIFT_WORKGROUP=acme-finance-dev
REDSHIFT_DATABASE=acme
REDSHIFT_ADMIN_SECRET_ARN=

# Bedrock
BEDROCK_AGENT_ID=
BEDROCK_KB_ID=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20250101-v1:0

# Generator seed (deterministic data)
ACME_SEED=20260501
